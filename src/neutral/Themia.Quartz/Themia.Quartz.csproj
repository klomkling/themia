<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <RootNamespace>Themia.Quartz</RootNamespace>
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
    <!-- Concessions for vendored SilkierQuartz dashboard source (Dashboard/**) — authored Themia.Quartz
         code (History/, ThemiaQuartzOptions, extensions) remains fully warning-clean.
         CS8600-CS8765: nullable-reference family (vendored source predates Nullable=enable).
         CS1591: missing XML docs on vendored public controllers/models.
         RS0016: vendored public MVC controllers are discovered by ApplicationPart, not a curated
         public API; authored types (ThemiaQuartzOptions, History/*) ARE tracked in PublicAPI.Unshipped.txt. -->
    <NoWarn>$(NoWarn);CS8600;CS8601;CS8602;CS8603;CS8604;CS8618;CS8625;CS8629;CS8765;CS1591;RS0016</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Quartz" />
    <!-- Dependencies of the vendored SilkierQuartz dashboard (Dashboard/** subtree):
           - Handlebars.Net: the dashboard's view engine (direct).
           - Newtonsoft.Json: used DIRECTLY by the vendored dashboard code (controllers, view models,
             HandlebarsHelpers, TypeHandlerService) — NOT just transitive; also pulled transitively by
             JsonSubTypes + Microsoft.AspNetCore.Mvc.NewtonsoftJson.
           - JsonSubTypes: polymorphic (de)serialization of the job-data type handlers (needs Newtonsoft).
         Themia is System.Text.Json-first; per the scheduling design spec, Newtonsoft here is an ACCEPTED
         vendoring trade-off — confined to the vendored dashboard, kept OFF Themia.Quartz's public API, and
         used by NO authored code (History store / options / extensions / the Scheduling module use STJ or
         none). Removing it would require rewriting the vendored dashboard's JSON layer (deferred). -->
    <PackageReference Include="Handlebars.Net" />
    <PackageReference Include="JsonSubTypes" />
    <PackageReference Include="Newtonsoft.Json" />
    <!-- MVC Newtonsoft formatter for the dashboard controllers (AddNewtonsoftJson). -->
    <PackageReference Include="Microsoft.AspNetCore.Mvc.NewtonsoftJson" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Dashboard\Content\**" />
    <EmbeddedResource Include="Dashboard\Views\**" />
    <EmbeddedResource Include="Dashboard\TypeHandlers\*.hbs" />
    <EmbeddedResource Include="Dashboard\TypeHandlers\*.js" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>
</Project>
