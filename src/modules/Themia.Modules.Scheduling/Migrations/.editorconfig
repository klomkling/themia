# EF Core generates public partial Migration classes (Up/Down/BuildTargetModel) that are not part
# of the package's curated public API surface and intentionally use nullable-oblivious EF types.
# Exempt the generated Migrations from the PublicAPI analyzer in this folder only.
[*.cs]
dotnet_diagnostic.RS0016.severity = none
dotnet_diagnostic.RS0017.severity = none
dotnet_diagnostic.RS0037.severity = none
dotnet_diagnostic.RS0041.severity = none
