<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Isolate this repo from any inherited (parent-directory) package sources.
    Central Package Management requires a single source (or source mapping);
    Themia's neutral/framework packages only need nuget.org.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
